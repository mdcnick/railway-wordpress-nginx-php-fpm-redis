# =============================================================================
# SERVER
# =============================================================================
PORT=${{PORT}}

# =============================================================================
# DATABASE (shared Railway MySQL)
# =============================================================================
MYSQL_HOST=${{MySQL.MYSQLHOST}}
MYSQL_PORT=${{MySQL.MYSQLPORT}}
MYSQL_USER=${{MySQL.MYSQLUSER}}
MYSQL_PASSWORD=${{MySQL.MYSQLPASSWORD}}
DASHBOARD_DB_NAME=wp_dashboard

# =============================================================================
# REDIS (passed to new WP sites)
# =============================================================================
REDIS_HOST=${{Redis.REDISHOST}}
REDIS_PORT=${{Redis.REDISPORT}}
REDIS_PASSWORD=${{Redis.REDISPASSWORD}}

# =============================================================================
# RAILWAY API
# =============================================================================
RAILWAY_API_TOKEN=
RAILWAY_PROJECT_ID=${{RAILWAY_PROJECT_ID}}
RAILWAY_ENVIRONMENT_ID=${{RAILWAY_ENVIRONMENT_ID}}
RAILWAY_WP_REPO=owner/repo-name
RAILWAY_WEBHOOK_SECRET=

# =============================================================================
# OBJECT STORAGE (Railway bucket — "AWS SDK Generic" style)
# =============================================================================
AWS_ENDPOINT_URL=${{collapsible-trough.ENDPOINT}}
AWS_S3_BUCKET_NAME=${{collapsible-trough.BUCKET}}
AWS_DEFAULT_REGION=${{collapsible-trough.REGION}}
AWS_ACCESS_KEY_ID=${{collapsible-trough.ACCESS_KEY_ID}}
AWS_SECRET_ACCESS_KEY=${{collapsible-trough.SECRET_ACCESS_KEY}}

# =============================================================================
# CLERK AUTH
# =============================================================================
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
VITE_CLERK_PUBLISHABLE_KEY=
