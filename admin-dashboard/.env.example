# Clerk Auth
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...  # Same as above, needed at build time

# Railway API
RAILWAY_API_TOKEN=
RAILWAY_PROJECT_ID=
RAILWAY_ENVIRONMENT_ID=          # Optional, auto-detected if not set
RAILWAY_WP_REPO=owner/repo-name  # GitHub repo for WP template

# MySQL (shared Railway MySQL)
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
DASHBOARD_DB_NAME=wp_dashboard

# Redis (passed to new WP sites)
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# Server
PORT=3000
